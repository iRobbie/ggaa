<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}} - Admin Panel</title>
    
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Font Awesome Icons (Filled Style) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Custom Admin CSS -->
    <link rel="stylesheet" href="/assets/css/admin.css">
    
    <!-- Page-specific styles -->
    {{#if pageStyles}}
        {{#each pageStyles}}
            <link rel="stylesheet" href="{{this}}">
        {{/each}}
    {{/if}}
</head>
<body>
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <nav class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <h3 class="brand-title">
                    <i class="fas fa-couch me-2"></i>
                    Furniture CMS
                </h3>
                <button class="btn-close sidebar-close d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#adminSidebar">
                    <span class="visually-hidden">Close sidebar</span>
                </button>
            </div>
            
            <div class="sidebar-content">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'dashboard')}}active{{/if}}" href="/admin/dashboard">
                            <i class="fas fa-tachometer-alt me-2"></i>
                            Dashboard
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'products')}}active{{/if}}" href="/admin/products">
                            <i class="fas fa-box me-2"></i>
                            Products
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'sliders')}}active{{/if}}" href="/admin/sliders">
                            <i class="fas fa-images me-2"></i>
                            Hero Sliders
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'banners')}}active{{/if}}" href="/admin/banners">
                            <i class="fas fa-ad me-2"></i>
                            Banners
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'content')}}active{{/if}}" href="/admin/content">
                            <i class="fas fa-edit me-2"></i>
                            Content
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'seo')}}active{{/if}}" href="/admin/seo">
                            <i class="fas fa-search me-2"></i>
                            SEO Settings
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'media')}}active{{/if}}" href="/admin/media">
                            <i class="fas fa-photo-video me-2"></i>
                            Media Library
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'users')}}active{{/if}}" href="/admin/users">
                            <i class="fas fa-users me-2"></i>
                            Users
                        </a>
                    </li>
                    
                    <li class="nav-item">
                        <a class="nav-link {{#if (eq currentPage 'settings')}}active{{/if}}" href="/admin/settings">
                            <i class="fas fa-cog me-2"></i>
                            Settings
                        </a>
                    </li>
                </ul>
            </div>
        </nav>
        
        <!-- Main Content -->
        <div class="admin-main">
            <!-- Top Navigation -->
            <header class="admin-header">
                <div class="container-fluid">
                    <div class="row align-items-center">
                        <div class="col">
                            <button class="btn btn-link sidebar-toggle d-lg-none" type="button" data-bs-toggle="collapse" data-bs-target="#adminSidebar">
                                <i class="fas fa-bars"></i>
                            </button>
                            <h1 class="page-title">{{title}}</h1>
                        </div>
                        
                        <div class="col-auto">
                            <div class="header-actions">
                                <!-- Notifications -->
                                <div class="dropdown me-3">
                                    <button class="btn btn-link position-relative" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-bell"></i>
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            3
                                        </span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><h6 class="dropdown-header">Notifications</h6></li>
                                        <li><a class="dropdown-item" href="#">New product added</a></li>
                                        <li><a class="dropdown-item" href="#">Slider updated</a></li>
                                        <li><a class="dropdown-item" href="#">Content modified</a></li>
                                    </ul>
                                </div>
                                
                                <!-- User Menu -->
                                <div class="dropdown">
                                    <button class="btn btn-link dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                        <img src="{{user.avatar_url}}" alt="{{user.first_name}}" class="avatar me-2" onerror="this.src='/assets/images/default-avatar.png'">
                                        <span>{{user.first_name}} {{user.last_name}}</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><h6 class="dropdown-header">Account</h6></li>
                                        <li><a class="dropdown-item" href="/admin/profile"><i class="fas fa-user me-2"></i>Profile</a></li>
                                        <li><a class="dropdown-item" href="/admin/settings"><i class="fas fa-cog me-2"></i>Settings</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="/auth/logout"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>
            
            <!-- Page Content -->
            <main class="admin-content">
                <div class="container-fluid">
                    <!-- Breadcrumb -->
                    {{#if breadcrumbs}}
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            {{#each breadcrumbs}}
                            <li class="breadcrumb-item {{#if @last}}active{{/if}}">
                                {{#if @last}}
                                    {{title}}
                                {{else}}
                                    <a href="{{url}}">{{title}}</a>
                                {{/if}}
                            </li>
                            {{/each}}
                        </ol>
                    </nav>
                    {{/if}}
                    
                    <!-- Flash Messages -->
                    {{#if messages}}
                        {{#each messages}}
                        <div class="alert alert-{{type}} alert-dismissible fade show" role="alert">
                            {{message}}
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                        {{/each}}
                    {{/if}}
                    
                    <!-- Main Content -->
                    {{{body}}}
                </div>
            </main>
        </div>
    </div>
    
    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- Chart.js for dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Custom Admin JS -->
    <script src="/assets/js/admin.js"></script>
    
    <!-- Page-specific scripts -->
    {{#if pageScripts}}
        {{#each pageScripts}}
            <script src="{{this}}"></script>
        {{/each}}
    {{/if}}
</body>
</html>